{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mozaika.local/contracts/design-receipt-v1.schema.json",
  "title": "mozaika-design-receipt/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "run_id", "stage_id", "artifact_type", "artifact_id", "brandbook", "instructions_passed", "checks", "deviations", "owner_override_id", "status"],
  "properties": {
    "contract_version": {"const": "mozaika-design-receipt/v1"},
    "run_id": {"type": "string", "minLength": 1},
    "stage_id": {"type": "string", "minLength": 1},
    "artifact_type": {"enum": ["dashboard", "storytelling_cards", "selected_storytelling_card", "speaker_story_cards", "report", "presentation"]},
    "artifact_id": {"type": "string", "minLength": 1},
    "brandbook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "manifest_path", "manifest_sha256", "tokens_path", "reference_ids"],
      "properties": {
        "authority": {"const": "owner_brandbook"},
        "manifest_path": {"const": "data/brandbook/mozaika/manifest.json"},
        "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "tokens_path": {"const": "data/brandbook/mozaika/tokens.css"},
        "reference_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "instructions_passed": {"const": true},
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warm_canvas", "typography_hierarchy", "artifact_pattern", "semantic_palette", "source_proximity", "no_forbidden_default_theme", "service_metadata_hidden", "browser_verified"],
      "properties": {
        "warm_canvas": {"const": true},
        "typography_hierarchy": {"const": true},
        "artifact_pattern": {"const": true},
        "semantic_palette": {"const": true},
        "source_proximity": {"const": true},
        "no_forbidden_default_theme": {"const": true},
        "service_metadata_hidden": {"const": true},
        "dashboard_excludes_storytelling_cards": {"const": true},
        "aligned_grid": {"const": true},
        "charts_render_without_errors": {"const": true},
        "tables_readable": {"const": true},
        "filters_functional": {"const": true},
        "filter_reset_works": {"const": true},
        "table_search_functional": {"const": true},
        "table_sort_functional": {"const": true},
        "customization_controls_functional": {"const": true},
        "customization_reset_works": {"const": true},
        "responsive_no_overflow": {"const": true},
        "empty_states_clear": {"const": true},
        "console_errors_absent": {"const": true},
        "brand_palette_exact": {"const": true},
        "no_dark_card_theme": {"const": true},
        "diagram_rich": {"const": true},
        "smooth_page_transitions": {"const": true},
        "reduced_motion_fallback": {"const": true},
        "browser_verified": {"const": true}
      }
    },
    "deviations": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "owner_override_id": {"type": ["string", "null"], "minLength": 1},
    "status": {"const": "pass"}
  },
  "allOf": [
    {
      "if": {"properties": {"deviations": {"minItems": 1}}},
      "then": {"properties": {"owner_override_id": {"type": "string", "minLength": 1}}},
      "else": {"properties": {"owner_override_id": {"type": "null"}}}
    },
    {
      "if": {"properties": {"artifact_type": {"const": "dashboard"}}, "required": ["artifact_type"]},
      "then": {"properties": {"checks": {"required": ["dashboard_excludes_storytelling_cards", "aligned_grid", "charts_render_without_errors", "tables_readable", "filters_functional", "filter_reset_works", "table_search_functional", "table_sort_functional", "customization_controls_functional", "customization_reset_works", "responsive_no_overflow", "empty_states_clear", "console_errors_absent"]}}}
    },
    {
      "if": {"properties": {"artifact_type": {"enum": ["storytelling_cards", "selected_storytelling_card", "speaker_story_cards"]}}, "required": ["artifact_type"]},
      "then": {"properties": {"checks": {"required": ["brand_palette_exact", "no_dark_card_theme"]}}}
    },
    {
      "if": {"properties": {"artifact_type": {"const": "presentation"}}, "required": ["artifact_type"]},
      "then": {"properties": {"checks": {"required": ["diagram_rich", "smooth_page_transitions", "reduced_motion_fallback"]}}}
    }
  ]
}
