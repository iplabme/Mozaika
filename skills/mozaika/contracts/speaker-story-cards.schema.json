{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mozaika.local/contracts/speaker-story-cards-v1.schema.json",
  "title": "mozaika-speaker-story-cards/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version", "run_id", "scenario", "output_language", "deck_title",
    "research_brief_sha256", "selected_checkpoint_id", "selected_card_artifact_id",
    "outline_artifact_id", "outline_sha256", "presentation_artifact_id",
    "presentation_sha256", "html_artifact_id", "html_sha256", "template",
    "cards"
  ],
  "properties": {
    "contract_version": {"const": "mozaika-speaker-story-cards/v1"},
    "run_id": {"type": "string", "minLength": 1},
    "scenario": {"const": "insight_deck"},
    "output_language": {"type": "string", "minLength": 2},
    "deck_title": {"type": "string", "minLength": 1},
    "research_brief_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "selected_checkpoint_id": {"type": "string", "minLength": 1},
    "selected_card_artifact_id": {"type": "string", "minLength": 1},
    "outline_artifact_id": {"type": "string", "minLength": 1},
    "outline_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "presentation_artifact_id": {"type": "string", "minLength": 1},
    "presentation_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "html_artifact_id": {"type": "string", "minLength": 1},
    "html_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "sha256"],
      "properties": {
        "ref": {"const": "data/brandbook/mozaika/templates/speaker-story-cards.template.html"},
        "sha256": {"const": "6d9792d14d391165db9578c1c89b2b9b67a4dc62c24dcb6588286ab0f9e2d560"}
      }
    },
    "cards": {
      "type": "array",
      "minItems": 2,
      "maxItems": 60,
      "items": {"$ref": "#/$defs/card"}
    }
  },
  "$defs": {
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id", "order", "slide_id", "slide_type", "slide_title",
        "purpose", "say_this", "evidence_cues", "visual_cue", "transition",
        "timing_seconds"
      ],
      "properties": {
        "card_id": {"type": "string", "pattern": "^speaker-card-[a-z0-9][a-z0-9_-]{0,63}$"},
        "order": {"type": "integer", "minimum": 1},
        "slide_id": {"type": "string", "pattern": "^slide-[a-z0-9][a-z0-9_-]{0,63}$"},
        "slide_type": {"enum": ["title", "section", "content"]},
        "slide_title": {"type": "string", "minLength": 1, "maxLength": 300},
        "purpose": {"type": "string", "minLength": 1, "maxLength": 500},
        "say_this": {
          "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 500}
        },
        "evidence_cues": {
          "type": "array", "maxItems": 4,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["claim_id", "spoken_fact", "source_artifact_ids"],
            "properties": {
              "claim_id": {"type": "string", "minLength": 1},
              "spoken_fact": {"type": "string", "minLength": 1, "maxLength": 500},
              "source_artifact_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
            }
          }
        },
        "visual_cue": {"type": "string", "minLength": 1, "maxLength": 500},
        "transition": {"type": "string", "minLength": 1, "maxLength": 500},
        "caution": {"type": ["string", "null"], "minLength": 1, "maxLength": 500},
        "answer_if_asked": {"type": ["string", "null"], "minLength": 1, "maxLength": 700},
        "timing_seconds": {"type": "integer", "minimum": 10, "maximum": 300}
      },
      "allOf": [
        {
          "if": {"properties": {"slide_type": {"const": "content"}}, "required": ["slide_type"]},
          "then": {"properties": {"evidence_cues": {"minItems": 1}}}
        }
      ]
    }
  }
}
