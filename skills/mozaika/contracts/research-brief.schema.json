{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mozaika.local/contracts/research-brief-v1.schema.json",
  "title": "mozaika-research-brief/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "run_id", "scenario", "assignment_artifact_id", "assignment_sha256", "output_language", "research_title_verbatim", "main_question_verbatim", "requirements", "protected_verbatim", "comparison_normalization"],
  "properties": {
    "contract_version": {"const": "mozaika-research-brief/v1"},
    "run_id": {"type": "string", "minLength": 1},
    "scenario": {"enum": ["routine_report", "insight_deck", "weekly_autopilot"]},
    "assignment_artifact_id": {"type": "string", "minLength": 1},
    "assignment_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "output_language": {"type": "string", "minLength": 2, "maxLength": 12},
    "research_title_verbatim": {"type": ["string", "null"], "minLength": 1, "maxLength": 500},
    "main_question_verbatim": {"type": ["string", "null"], "minLength": 1, "maxLength": 2000},
    "comparison_normalization": {"const": "unicode-nfc-lf-v1"},
    "requirements": {
      "type": "array",
      "maxItems": 100,
      "items": {"$ref": "#/$defs/requirement"}
    },
    "protected_verbatim": {
      "type": "array",
      "maxItems": 120,
      "items": {"type": "string", "minLength": 1, "maxLength": 2000}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"scenario": {"const": "insight_deck"}}, "required": ["scenario"]},
      "then": {"properties": {"requirements": {"minItems": 1}}}
    }
  ],
  "$defs": {
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "text_verbatim", "category", "labels", "required_surfaces", "partial_answer_allowed", "data_stage_required"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^req-[a-z0-9][a-z0-9_-]{0,63}$"},
        "text_verbatim": {"type": "string", "minLength": 1, "maxLength": 2000},
        "category": {"enum": ["research_question", "requested_slice", "requested_section", "named_output", "constraint"]},
        "labels": {"type": "array", "maxItems": 20, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"}},
        "required_surfaces": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["data", "dashboard", "cards", "storyline", "presentation", "delivery"]}},
        "partial_answer_allowed": {"type": "boolean"},
        "data_stage_required": {"type": "boolean"}
      },
      "allOf": [
        {
          "if": {"properties": {"category": {"const": "constraint"}}, "required": ["category"]},
          "then": {"properties": {"data_stage_required": {"const": false}}}
        }
      ]
    }
  }
}
