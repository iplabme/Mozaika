{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mozaika.local/contracts/owner-decision-checkpoint-v1.schema.json",
  "title": "mozaika-owner-decision-checkpoint/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "checkpoint_id", "run_id", "decision_id", "chat_scope_id", "scenario", "state", "created_at", "stale_after", "discovery", "assignment_ref", "research_brief_ref", "dashboard_ref", "owner_choice_ref", "cards_ref", "candidate_options", "previous_checkpoint_id"],
  "properties": {
    "contract_version": {"const": "mozaika-owner-decision-checkpoint/v1"},
    "checkpoint_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "decision_id": {"type": "string", "minLength": 1},
    "chat_scope_id": {"type": "string", "minLength": 1},
    "scenario": {"const": "insight_deck"},
    "state": {"enum": ["pending", "selected", "superseded", "dismissed"]},
    "created_at": {"type": "string", "format": "date-time"},
    "stale_after": {"type": "string", "format": "date-time"},
    "previous_checkpoint_id": {"type": ["string", "null"], "minLength": 1},
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lookup_key", "visible_run_id", "priority"],
      "properties": {
        "lookup_key": {"type": "string", "minLength": 1},
        "visible_run_id": {"type": "string", "minLength": 4, "maxLength": 64},
        "priority": {"const": ["explicit_run_id", "single_pending_in_chat_scope", "ask_owner"]}
      }
    },
    "assignment_ref": {"$ref": "#/$defs/artifact_ref"},
    "research_brief_ref": {"$ref": "#/$defs/artifact_ref"},
    "dashboard_ref": {"$ref": "#/$defs/artifact_ref"},
    "owner_choice_ref": {"$ref": "#/$defs/artifact_ref"},
    "cards_ref": {"$ref": "#/$defs/artifact_ref"},
    "candidate_options": {"type": "array", "minItems": 2, "maxItems": 3, "items": {"$ref": "#/$defs/option"}},
    "selected_option_id": {"type": "string", "minLength": 1},
    "selected_card_ref": {"$ref": "#/$defs/artifact_ref"},
    "owner_message_artifact_id": {"type": "string", "minLength": 1},
    "superseded_by_checkpoint_id": {"type": "string", "minLength": 1},
    "dismissal_reason": {"type": "string", "minLength": 1, "maxLength": 1000}
  },
  "allOf": [
    {
      "if": {"properties": {"state": {"const": "pending"}}, "required": ["state"]},
      "then": {"not": {"anyOf": [{"required": ["selected_option_id"]}, {"required": ["selected_card_ref"]}, {"required": ["superseded_by_checkpoint_id"]}, {"required": ["dismissal_reason"]}]}}
    },
    {
      "if": {"properties": {"state": {"const": "selected"}}, "required": ["state"]},
      "then": {"required": ["selected_option_id", "selected_card_ref", "owner_message_artifact_id"], "not": {"anyOf": [{"required": ["superseded_by_checkpoint_id"]}, {"required": ["dismissal_reason"]}]}}
    },
    {
      "if": {"properties": {"state": {"const": "superseded"}}, "required": ["state"]},
      "then": {"required": ["selected_option_id", "selected_card_ref", "owner_message_artifact_id", "superseded_by_checkpoint_id"]}
    },
    {
      "if": {"properties": {"state": {"const": "dismissed"}}, "required": ["state"]},
      "then": {"required": ["dismissal_reason"]}
    }
  ],
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "uri", "sha256"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["option_id", "headline", "html_anchor"],
      "properties": {
        "option_id": {"type": "string", "minLength": 1},
        "headline": {"type": "string", "minLength": 1},
        "html_anchor": {"type": "string", "pattern": "^#[A-Za-z][A-Za-z0-9_-]*$"}
      }
    }
  }
}
