{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mozaika.local/contracts/visual-layout-audit-v1.schema.json",
  "title": "mozaika-visual-layout-audit/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "run_id", "audit_id", "artifact_type", "artifact_id", "artifact_sha256", "viewports", "checks", "issues", "status"],
  "properties": {
    "contract_version": {"const": "mozaika-visual-layout-audit/v1"},
    "run_id": {"type": "string", "minLength": 1},
    "audit_id": {"type": "string", "minLength": 1},
    "artifact_type": {"enum": ["dashboard", "presentation", "speaker_story_cards"]},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "viewports": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["width", "height", "screenshot_artifact_id", "overlap_count", "overflow_count", "spacing_outlier_count", "max_center_offset_px"],
        "properties": {
          "width": {"type": "integer", "minimum": 320, "maximum": 3840},
          "height": {"type": "integer", "minimum": 480, "maximum": 2160},
          "screenshot_artifact_id": {"type": "string", "minLength": 1},
          "overlap_count": {"const": 0},
          "overflow_count": {"const": 0},
          "spacing_outlier_count": {"const": 0},
          "max_center_offset_px": {"type": "number", "minimum": 0, "maximum": 2}
        }
      },
      "allOf": [
        {"contains": {"properties": {"width": {"minimum": 1280}}, "required": ["width"]}, "minContains": 1},
        {"contains": {"properties": {"width": {"minimum": 768, "maximum": 1279}}, "required": ["width"]}, "minContains": 1},
        {"contains": {"properties": {"width": {"maximum": 767}}, "required": ["width"]}, "minContains": 1}
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_screens_inspected", "no_unintended_overlaps", "charts_within_bounds", "consistent_peer_spacing", "declared_centers_are_centered", "no_unintended_page_overflow", "interactive_states_inspected", "console_errors_absent"],
      "properties": {
        "all_screens_inspected": {"const": true},
        "no_unintended_overlaps": {"const": true},
        "charts_within_bounds": {"const": true},
        "consistent_peer_spacing": {"const": true},
        "declared_centers_are_centered": {"const": true},
        "no_unintended_page_overflow": {"const": true},
        "interactive_states_inspected": {"const": true},
        "filter_options_backed_by_data": {"const": true},
        "filter_targets_recomputed": {"const": true},
        "cross_filter_consistent": {"const": true},
        "no_decorative_controls": {"const": true},
        "console_errors_absent": {"const": true}
      }
    },
    "issues": {"type": "array", "maxItems": 0},
    "status": {"const": "pass"}
  },
  "allOf": [
    {
      "if": {"properties": {"artifact_type": {"const": "dashboard"}}, "required": ["artifact_type"]},
      "then": {"properties": {"checks": {"required": ["filter_options_backed_by_data", "filter_targets_recomputed", "cross_filter_consistent", "no_decorative_controls"]}}}
    }
  ]
}
