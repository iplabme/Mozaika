{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mozaika.local/contracts/claim-registry-v1.schema.json",
  "title": "mozaika-claim-registry/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "run_id", "scope_ledger_sha256", "output_language", "claims"],
  "properties": {
    "contract_version": {"const": "mozaika-claim-registry/v1"},
    "run_id": {"type": "string", "minLength": 1},
    "scope_ledger_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "output_language": {"type": "string", "minLength": 2},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "text", "kind", "status", "quantitative", "entity_sensitive", "evidence_artifact_ids", "checks", "text_checks"],
        "properties": {
          "claim_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "text": {"type": "string", "minLength": 1},
          "kind": {"enum": ["observed", "calculated", "inference", "hypothesis", "recommendation"]},
          "status": {"enum": ["verified", "qualified"]},
          "quantitative": {"type": "boolean"},
          "entity_sensitive": {"type": "boolean"},
          "qualifier": {"type": "string", "minLength": 1},
          "evidence_artifact_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["operator", "left", "right", "claimed_value", "tolerance"],
              "properties": {
                "operator": {"enum": ["ratio_pct", "ratio", "difference", "sum", "equals"]},
                "left": {"type": "number"},
                "right": {"type": "number"},
                "claimed_value": {"type": "number"},
                "tolerance": {"type": "number", "minimum": 0}
              }
            }
          },
          "text_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["actual", "claimed", "case_sensitive"],
              "properties": {
                "actual": {"type": "string", "minLength": 1},
                "claimed": {"type": "string", "minLength": 1},
                "case_sensitive": {"type": "boolean"}
              }
            }
          },
          "caveats": {"type": "array", "items": {"type": "string"}}
        },
        "allOf": [
          {"if": {"properties": {"kind": {"enum": ["observed", "calculated"]}}}, "then": {"properties": {"status": {"const": "verified"}}}},
          {"if": {"properties": {"kind": {"enum": ["inference", "hypothesis", "recommendation"]}}}, "then": {"required": ["qualifier"], "properties": {"status": {"const": "qualified"}}}},
          {"if": {"properties": {"kind": {"const": "calculated"}}}, "then": {"properties": {"checks": {"minItems": 1}}}},
          {"if": {"properties": {"quantitative": {"const": true}}}, "then": {"properties": {"checks": {"minItems": 1}}}},
          {"if": {"properties": {"entity_sensitive": {"const": true}}}, "then": {"properties": {"text_checks": {"minItems": 1}}}}
        ]
      }
    }
  }
}
