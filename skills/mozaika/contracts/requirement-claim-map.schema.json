{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mozaika.local/contracts/requirement-claim-map-v1.schema.json",
  "title": "mozaika-requirement-claim-map/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "run_id", "research_brief_sha256", "entries", "global_constraints"],
  "properties": {
    "contract_version": {"const": "mozaika-requirement-claim-map/v1"},
    "run_id": {"type": "string", "minLength": 1},
    "research_brief_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "entries": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/entry"}},
    "global_constraints": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/constraint"}}
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "text_verbatim", "status", "claim_ids", "evidence_artifact_ids", "available_dimensions", "reason"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^req-[a-z0-9][a-z0-9_-]{0,63}$"},
        "text_verbatim": {"type": "string", "minLength": 1, "maxLength": 2000},
        "status": {"enum": ["answered", "partial", "unanswered", "not_applicable"]},
        "claim_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "evidence_artifact_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "available_dimensions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "reason": {"type": ["string", "null"], "minLength": 1, "maxLength": 1000}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "answered"}}, "required": ["status"]},
          "then": {"properties": {"claim_ids": {"minItems": 1}, "evidence_artifact_ids": {"minItems": 1}, "reason": {"type": "null"}}}
        },
        {
          "if": {"properties": {"status": {"enum": ["partial", "unanswered", "not_applicable"]}}, "required": ["status"]},
          "then": {"properties": {"reason": {"type": "string", "minLength": 1}}}
        }
      ]
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "text_verbatim", "applied_global", "checked_surfaces"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^req-[a-z0-9][a-z0-9_-]{0,63}$"},
        "text_verbatim": {"type": "string", "minLength": 1, "maxLength": 2000},
        "applied_global": {"const": true},
        "checked_surfaces": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["data", "dashboard", "cards", "storyline", "presentation", "delivery"]}}
      }
    }
  }
}
