{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mozaika.local/contracts/owner-domain-profile-v1.schema.json",
  "title": "mozaika-owner-domain-profile/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "profile_id", "knowledge_key", "domain", "decision_context", "analysis_preferences", "learned_signals", "feedback_history", "governance", "predecessor_sha256", "updated_at"],
  "properties": {
    "contract_version": {"const": "mozaika-owner-domain-profile/v1"},
    "profile_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "knowledge_key": {"type": "string", "pattern": "^mozaika-owner-domain-[a-z0-9][a-z0-9-]*$"},
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "glossary", "entity_hierarchies", "time_grains", "priority_kpis"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "glossary": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "entity_hierarchies": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "time_grains": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "priority_kpis": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "decision_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audiences", "recurring_decisions", "priority_questions"],
      "properties": {
        "audiences": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "recurring_decisions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "priority_questions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "analysis_preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preferred_dimensions", "preferred_slices", "comparison_baselines", "evidence_threshold", "recommendation_style"],
      "properties": {
        "preferred_dimensions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "preferred_slices": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "comparison_baselines": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "evidence_threshold": {"enum": ["exploratory", "decision-grade", "strict"]},
        "recommendation_style": {"type": "string", "minLength": 1}
      }
    },
    "learned_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signal_id", "category", "value", "provenance", "evidence_refs", "confidence", "status", "first_seen_at", "last_seen_at"],
        "properties": {
          "signal_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
          "category": {"enum": ["kpi", "slice", "filter", "audience", "decision", "baseline", "insight", "storyline", "correction"]},
          "value": {"type": "string", "minLength": 1},
          "provenance": {"enum": ["explicit_statement", "owner_choice", "owner_correction", "accepted_result", "repeated_observation"]},
          "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "status": {"enum": ["confirmed", "provisional", "rejected", "stale"]},
          "first_seen_at": {"type": "string", "format": "date-time"},
          "last_seen_at": {"type": "string", "format": "date-time"}
        }
      }
    },
    "feedback_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_or_insight_id", "decision", "reason", "evidence_ref", "recorded_at"],
        "properties": {
          "artifact_or_insight_id": {"type": "string", "minLength": 1},
          "decision": {"enum": ["accepted", "rejected", "corrected", "noted"]},
          "reason": {"type": "string", "minLength": 1},
          "evidence_ref": {"type": "string", "minLength": 1},
          "recorded_at": {"type": "string", "format": "date-time"}
        }
      }
    },
    "governance": {
      "const": {
        "owner_visible_and_editable": true,
        "versioned_not_overwritten": true,
        "no_sensitive_inference": true,
        "training_mode": "profile_memory_not_model_weights",
        "material_profile_changes_require_confirmation": true,
        "provisional_signals_cannot_drive_material_recommendations": true
      }
    },
    "predecessor_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
